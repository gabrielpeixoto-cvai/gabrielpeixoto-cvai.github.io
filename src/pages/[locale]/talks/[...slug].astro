---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { LOCALES } from '../../../i18n/ui.mjs';
import { parseEntryId, findLocalized } from '../../../i18n/content.mjs';

export async function getStaticPaths() {
  const all = await getCollection('talks');
  const baseIds = [...new Set(all.map((e) => parseEntryId(e.id).baseId))];
  return LOCALES.flatMap((locale) =>
    baseIds.map((baseId) => ({
      params: { locale, slug: baseId },
      props: { entry: findLocalized(all, baseId, locale)!, locale },
    }))
  );
}
const { entry, locale } = Astro.props;
const { Content } = await render(entry);
const meta = [entry.data.type, entry.data.venue, entry.data.location,
  entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })]
  .filter(Boolean).join(' · ');
---
<BaseLayout locale={locale} title={entry.data.title} description={entry.data.excerpt}>
  <article>
    <h1>{entry.data.title}</h1>
    <p style="color:var(--muted);">{meta}</p>
    <Content />
  </article>
</BaseLayout>
