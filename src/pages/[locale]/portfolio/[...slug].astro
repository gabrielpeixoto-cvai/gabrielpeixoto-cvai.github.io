---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { LOCALES, t } from '../../../i18n/ui.mjs';
import { findLocalized, englishBaseIds } from '../../../i18n/content.mjs';

export async function getStaticPaths() {
  const all = await getCollection('portfolio');
  const baseIds = englishBaseIds(all);
  return LOCALES.flatMap((locale) =>
    baseIds.map((baseId) => ({
      params: { locale, slug: baseId },
      props: { entry: findLocalized(all, baseId, locale)!, locale },
    }))
  );
}
const { entry, locale } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout locale={locale} title={entry.data.title} description={entry.data.excerpt}>
  <article>
    <h1>{entry.data.title}</h1>
    {entry.data.image && <img src={entry.data.image} alt={entry.data.title} />}
    {entry.data.link && <p><a href={entry.data.link} target="_blank" rel="noopener noreferrer">{t(locale, 'label.projectLink')}</a></p>}
    <Content />
  </article>
</BaseLayout>
