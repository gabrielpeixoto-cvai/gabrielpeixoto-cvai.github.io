---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryList from '../../../components/EntryList.astro';
import { LOCALES, t } from '../../../i18n/ui.mjs';
import { localizedEntries, parseEntryId } from '../../../i18n/content.mjs';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}
const { locale } = Astro.params as { locale: string };
const projects = localizedEntries(await getCollection('projects'), locale)
  .filter((p) => p.data.unlisted !== true)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const items = projects.map((p) => ({
  title: p.data.title,
  href: `/${locale}/projects/${parseEntryId(p.id).baseId}/`,
  meta: [p.data.venue, p.data.date.getFullYear()].filter(Boolean).join(' · '),
  excerpt: p.data.excerpt,
}));
---
<BaseLayout locale={locale} title={t(locale, 'heading.projects')} description="Project pages by Gabriel Peixoto de Carvalho.">
  <h1>{t(locale, 'heading.projects')}</h1>
  <EntryList items={items} empty={t(locale, 'empty.projects')} />
</BaseLayout>
