---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PublicationCard from '../../../components/PublicationCard.astro';
import { LOCALES, t } from '../../../i18n/ui.mjs';
import { localizedEntries, parseEntryId } from '../../../i18n/content.mjs';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}
const { locale } = Astro.params as { locale: string };
const pubs = localizedEntries(await getCollection('publications'), locale)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout locale={locale} title={t(locale, 'heading.publications')} description="Publications by Gabriel Peixoto de Carvalho.">
  <h1>{t(locale, 'heading.publications')}</h1>
  {pubs.length === 0 ? (
    <p style="color:var(--muted);">{t(locale, 'empty.publications')}</p>
  ) : (
    pubs.map((p) => (
      <PublicationCard
        title={p.data.title}
        venue={p.data.venue}
        date={p.data.date}
        excerpt={p.data.excerpt}
        href={`/${locale}/publications/${parseEntryId(p.id).baseId}/`}
      />
    ))
  )}
</BaseLayout>
