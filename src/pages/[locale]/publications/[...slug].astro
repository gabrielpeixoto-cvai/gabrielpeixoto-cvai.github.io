---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { LOCALES, t } from '../../../i18n/ui.mjs';
import { findLocalized, englishBaseIds } from '../../../i18n/content.mjs';

export async function getStaticPaths() {
  const all = await getCollection('publications');
  const baseIds = englishBaseIds(all);
  return LOCALES.flatMap((locale) =>
    baseIds.map((baseId) => ({
      params: { locale, slug: baseId },
      props: { entry: findLocalized(all, baseId, locale)!, locale },
    }))
  );
}
const { entry, locale } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout locale={locale} title={entry.data.title} description={entry.data.excerpt}>
  <article>
    <h1>{entry.data.title}</h1>
    <p style="color:var(--muted);">{entry.data.venue} · {entry.data.date.getFullYear()}</p>
    {entry.data.paperurl && <p><a href={entry.data.paperurl}>{t(locale, 'label.paperPdf')}</a></p>}
    <Content />
    <h2>{t(locale, 'label.citation')}</h2>
    <p set:html={entry.data.citation}></p>
  </article>
</BaseLayout>
