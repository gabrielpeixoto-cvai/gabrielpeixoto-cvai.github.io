---
interface Item { title: string; href: string; meta?: string; excerpt?: string; }
interface Props { items: Item[]; empty?: string; }
const { items, empty = 'Nothing here yet.' } = Astro.props;
---
{items.length === 0 ? (
  <p style="color:var(--muted);">{empty}</p>
) : (
  items.map((it) => (
    <article style="padding:1rem 0;border-bottom:1px solid var(--border);">
      <a href={it.href} style="font-weight:600;font-size:1.05rem;">{it.title}</a>
      {it.meta && <div style="color:var(--muted);font-size:.9rem;margin-top:.25rem;">{it.meta}</div>}
      {it.excerpt && <p style="margin:.5rem 0 0;">{it.excerpt}</p>}
    </article>
  ))
)}
