---
import { siteConfig } from '../site.config';
import { t } from '../i18n/ui.mjs';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props { locale: string; }
const { locale } = Astro.props;
---
<header style="border-bottom:1px solid var(--border);">
  <nav style="max-width:var(--max-width);margin:0 auto;padding:1rem;display:flex;gap:1rem;align-items:center;">
    <a href={`/${locale}/`} style="font-weight:700;text-decoration:none;color:var(--fg);">{siteConfig.name}</a>
    <div style="margin-left:auto;display:flex;gap:1rem;align-items:center;">
      {siteConfig.nav.map((item) => <a href={`/${locale}${item.href}`}>{t(locale, item.key)}</a>)}
      <LanguageSwitcher locale={locale} />
      <ThemeToggle />
    </div>
  </nav>
</header>
