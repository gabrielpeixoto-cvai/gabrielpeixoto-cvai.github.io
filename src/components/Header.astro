---
import { siteConfig } from '../site.config';
import ThemeToggle from './ThemeToggle.astro';
---
<header style="border-bottom:1px solid var(--border);">
  <nav style="max-width:var(--max-width);margin:0 auto;padding:1rem;display:flex;gap:1rem;align-items:center;">
    <a href="/" style="font-weight:700;text-decoration:none;color:var(--fg);">{siteConfig.name}</a>
    <div style="margin-left:auto;display:flex;gap:1rem;align-items:center;">
      {siteConfig.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <ThemeToggle />
    </div>
  </nav>
</header>
