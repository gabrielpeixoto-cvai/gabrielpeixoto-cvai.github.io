---
// Simple client-side password gate. Deterrence only: the gated content is
// still present in the static HTML and readable via View Source. Verifies a
// typed password's SHA-256 against the embedded hash and, on match, removes
// the overlay and remembers the unlock for the browser session.
interface Props { hash: string; title: string; }
const { hash, title } = Astro.props;
---
<div id="pw-gate" class="pw-gate" data-hash={hash}>
  <form id="pw-form" class="pw-box">
    <h1 class="pw-title">Private preview</h1>
    <p class="pw-sub">“{title}” is a private page. Enter the password to view it.</p>
    <input id="pw-input" type="password" autocomplete="off" autofocus class="pw-input" aria-label="Password" />
    <button type="submit" class="pw-submit">Unlock</button>
    <p id="pw-error" class="pw-error" role="alert" hidden>Incorrect password — try again.</p>
  </form>
</div>

<style>
  .pw-gate {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--bg);
  }
  .pw-box {
    width: 100%;
    max-width: 22rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    text-align: center;
  }
  .pw-title { margin: 0; font-size: 1.4rem; }
  .pw-sub { margin: 0 0 .5rem; color: var(--muted); font-size: .95rem; }
  .pw-input {
    width: 100%;
    padding: .6rem .75rem;
    font: inherit;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .pw-input:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
  .pw-submit {
    padding: .6rem .75rem;
    font: inherit;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }
  .pw-error { margin: 0; color: #dc2626; font-size: .9rem; }
</style>

<script>
  const gate = document.getElementById('pw-gate');
  const content = document.getElementById('gated-content');
  const expected = gate?.dataset.hash || '';
  const KEY = `pw-gate:${expected}`;

  const reveal = () => {
    gate?.remove();
    if (content) content.style.visibility = '';
    document.documentElement.style.overflow = '';
  };

  async function sha256(text: string) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
    return Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, '0')).join('');
  }

  if (expected && sessionStorage.getItem(KEY) === '1') {
    reveal();
  } else {
    document.documentElement.style.overflow = 'hidden';
    const form = document.getElementById('pw-form') as HTMLFormElement | null;
    const input = document.getElementById('pw-input') as HTMLInputElement | null;
    const err = document.getElementById('pw-error');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!input) return;
      const got = await sha256(input.value);
      if (got === expected) {
        sessionStorage.setItem(KEY, '1');
        reveal();
      } else if (err) {
        err.hidden = false;
        input.value = '';
        input.focus();
      }
    });
  }
</script>
