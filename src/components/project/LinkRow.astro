---
interface LinkItem { label: string; href: string; }
interface Props { links: LinkItem[]; }
const { links } = Astro.props;
---
{links.length > 0 && (
  <nav aria-label="Project links" style="display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;margin:1rem 0;">
    {links.map((l) => (
      <a
        href={l.href}
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-block;padding:.5rem 1rem;border:1px solid var(--border);border-radius:6px;text-decoration:none;color:var(--fg);"
      >{l.label}</a>
    ))}
  </nav>
)}
