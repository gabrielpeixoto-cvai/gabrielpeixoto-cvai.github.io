---
interface Props { src: string; poster?: string; }
const { src, poster } = Astro.props;

// Map common share URLs to their embeddable form; null => treat src as a video file.
function embedUrl(u: string): string | null {
  const yt = u.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  const vimeo = u.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return null;
}
const embed = embedUrl(src);
---
<div style="position:relative;width:100%;aspect-ratio:16/9;margin:1rem 0;">
  {embed ? (
    <iframe
      src={embed}
      title="Project video"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      style="position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:8px;"
    ></iframe>
  ) : (
    <video controls poster={poster} style="position:absolute;inset:0;width:100%;height:100%;border-radius:8px;background:#000;">
      <source src={src} type="video/mp4" />
    </video>
  )}
</div>
