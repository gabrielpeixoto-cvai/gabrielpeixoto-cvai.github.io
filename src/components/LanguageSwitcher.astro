---
import { LOCALES, t } from '../i18n/ui.mjs';

interface Props { locale: string; }
const { locale } = Astro.props;

const LABELS: Record<string, string> = { en: 'EN', ja: '日本語', 'pt-br': 'PT-BR' };
// Strip the leading /<locale>/ segment to get the shared tail, then re-prefix per locale.
const tail = Astro.url.pathname.replace(/^\/(en|ja|pt-br)(?=\/|$)/, '');
---
<div role="group" aria-label={t(locale, 'label.language')} style="display:flex;gap:.5rem;align-items:center;font-size:.9rem;">
  {LOCALES.map((l) => (
    <a href={`/${l}${tail || '/'}`} aria-current={l === locale ? 'true' : undefined}>{LABELS[l]}</a>
  ))}
</div>
